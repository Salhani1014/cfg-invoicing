{
  "name": "cfg-invoicing",
  "productName": "CFG Invoicing",
  "version": "1.0.3",
  "description": "Checkmate Financial Group Invoice Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg",
    "test": "jest"
  },
  "build": {
    "appId": "com.checkmatefinancialgroup.invoicing",
    "productName": "CFG Invoicing",
    "icon": "assets/icon.icns",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.test.js",
      "!tests/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "CFG Invoicing"
    },
    "publish": {
      "provider": "github",
      "owner": "Salhani1014",
      "repo": "cfg-invoicing"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "electron-updater": "^6.8.3",
    "nodemailer": "^6.9.0"
  }
}
